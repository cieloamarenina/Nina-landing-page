# ============================================================
# Hanteltraining_Nina · Environment Variables
# ============================================================
# Template — committed ins Repo
# Für lokale Nutzung: cp .env.example .env (gitignored)
# Für Production: in Coolify als Env Variables setzen
# ============================================================


# ────────────────────────────────────────────────────────────
# FRONTEND VARIABLES (öffentlich, kein Secret)
# Werte werden in hanteltraining/config.js synchronisiert
# ────────────────────────────────────────────────────────────

# Standardsprache (de | en | es | fr | it)
DEFAULT_LANG=de

# Verfügbare Sprachen (Komma-getrennt)
ENABLED_LANGS=de,en,es,fr,it

# Spotify-Playlists (Format: ID|Anzeigename, Komma-getrennt)
# ID = Teil zwischen /playlist/ und ?si= in der Spotify-URL
SPOTIFY_PLAYLISTS=2R10VQvUU02ga3185KXjR6|Top All-Time,XXXXX|Workout Mix,YYYYY|Chill Vibes

# Pfad zum Pablo-Foto (relativ zu hanteltraining/index.html)
PABLO_IMAGE_PATH=../assets/pablo.jpg


# ────────────────────────────────────────────────────────────
# TRACKING (optional, Phase 2)
# ────────────────────────────────────────────────────────────

# An/aus (true | false)
TRACKING_ENABLED=false

# n8n Webhook URLs
WEBHOOK_VISIT=https://n8n.ninalearnsvibecoding.com/webhook/workout-visit
WEBHOOK_COMPLETE=https://n8n.ninalearnsvibecoding.com/webhook/workout-complete


# ────────────────────────────────────────────────────────────
# BACKEND VARIABLES (SECRET — nur in n8n-Coolify)
# NIE ins Frontend, NIE in config.js, NIE committen
# ────────────────────────────────────────────────────────────

NOCODB_URL=https://nocodb.ninalearnsvibecoding.com
NOCODB_API_TOKEN=xxxxxxxxxxxxxxxxxxxxx
NOCODB_PROJECT_ID=p_xxxxxxxxxxxx
NOCODB_TABLE_ID=md_xxxxxxxxxxxx


# ────────────────────────────────────────────────────────────
# SYNC HINWEIS
# Manuelles Übertragen .env → hanteltraining/config.js
# oder Coolify Pre-Deploy-Script
# ────────────────────────────────────────────────────────────
